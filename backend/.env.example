# Core server
PORT=4001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# OpenAI (required for planning)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Inngest (required in production if using async queue mode)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_APP_ID=far-away-assistant

# Clerk (required for protected routes and dashboard)
CLERK_SECRET_KEY=sk_test_...

# Optional local-dev fallback only. Do NOT use in production.
ASSISTANT_DEFAULT_CLERK_USER_ID=

# Supabase (required)
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Required for token encryption (OAuth tokens and desktop pairing tokens)
TOKEN_ENCRYPTION_KEY=<32-byte-base64-or-strong-random-string>

# Google OAuth (required for user-based Gmail/Calendar/Sheets access)
GOOGLE_OAUTH_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<your-google-oauth-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4001/api/auth/google/callback

# Google defaults (optional)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_CALENDAR_ID=primary
GMAIL_SENDER_EMAIL=

# Service account mode (optional fallback if user OAuth is not used)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PROJECT_ID=

# Dev/testing
GOOGLE_MOCK_MODE=false
